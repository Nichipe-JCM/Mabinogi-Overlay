<Window x:Class="TestOverlay.App.LayoutEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay Layout Editor"
        Width="980"
        Height="720"
        MinWidth="760"
        MinHeight="520"
        Background="#F3F5F7">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#111827">
            <Border BorderBrush="#2F3645" BorderThickness="1" Background="#202633">
                <Canvas x:Name="EditorCanvas"
                        Background="#202633"
                        MouseMove="EditorCanvas_MouseMove"
                        MouseLeftButtonUp="EditorCanvas_MouseLeftButtonUp"/>
            </Border>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="96" Height="34" Content="Close" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
