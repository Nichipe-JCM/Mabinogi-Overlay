<Window x:Class="TestOverlay.App.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TestOverlay.App.Services"
        Title="Session Log"
        loc:Localize.TitleKey="Session Log"
        Icon="/Image/AppIcon.ico"
        Width="1040"
        Height="680"
        MinWidth="720"
        MinHeight="420"
        Background="{StaticResource OverlayBgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18" Style="{StaticResource AppWindowRootStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Session Log" loc:Localize.TextKey="Session Log" FontSize="22" FontWeight="Bold" Foreground="{StaticResource OverlayAccentBrush}"/>
            <TextBlock x:Name="LogPathText" Style="{StaticResource MutedTextStyle}"/>
        </StackPanel>
        <Border Grid.Row="1" Style="{StaticResource GlassCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource CardHeaderStyle}">
                    <TextBlock x:Name="LogSummaryText" Style="{StaticResource MutedTextStyle}"/>
                </Border>
                <TextBox x:Name="LogTextBox"
                         Grid.Row="1"
                         Margin="12"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="12"/>
            </Grid>
        </Border>
        <WrapPanel Grid.Row="2" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Width="88" Height="34" Content="Refresh" loc:Localize.ContentKey="Refresh" Click="RefreshButton_Click"/>
            <Button Width="88" Height="34" Margin="8,0,0,0" Content="Close" loc:Localize.ContentKey="Close" Click="CloseButton_Click"/>
        </WrapPanel>
    </Grid>
</Window>
