<Window x:Class="TestOverlay.App.ProfileNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TestOverlay.App.Services"
        xmlns:controls="clr-namespace:TestOverlay.App.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Save Profile"
        loc:Localize.TitleKey="Save Profile"
        Icon="/Image/AppIcon.ico"
        Width="390"
        Height="238"
        MinWidth="340"
        MinHeight="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource OverlayBgBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid Margin="8,4,8,8" Style="{StaticResource AppWindowRootStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:AppTitleBar Grid.Row="0"/>

        <Border Grid.Row="1" Padding="16" Style="{StaticResource GlassCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Profile name" loc:Localize.TextKey="Profile name" Style="{StaticResource SectionTitleStyle}"/>
                <TextBox Grid.Row="1" x:Name="ProfileNameBox" Height="34" Margin="0,10,0,0"/>
                <TextBlock Grid.Row="2" x:Name="ErrorText" Margin="0,8,0,0" Style="{StaticResource DangerTextStyle}"/>

                <WrapPanel Grid.Row="3" HorizontalAlignment="Right">
                    <Button MinWidth="84" Height="34" Padding="14,0" Content="Cancel" loc:Localize.ContentKey="Cancel" Click="CancelButton_Click"/>
                    <Button MinWidth="84" Height="34" Padding="14,0" Margin="8,0,0,0" Content="Save" loc:Localize.ContentKey="Save" Click="SaveButton_Click"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
