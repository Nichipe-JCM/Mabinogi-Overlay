<UserControl x:Class="TestOverlay.App.Controls.AppTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">
    <Border Margin="0,0,0,8"
            Style="{StaticResource GlassCardStyle}"
            PreviewMouseLeftButtonDown="TitleBarArea_PreviewMouseLeftButtonDown">
        <Grid Height="42" Margin="12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0"
                   Source="/Image/Logo.png"
                   Width="24"
                   Height="24"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=Title}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource OverlayAccentBrush}"/>
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Width="34" Height="28" Margin="4,0,0,0" Click="MinimizeButton_Click">
                    <TextBlock Text="&#x1F5D5;"
                               FontFamily="Segoe UI Symbol, Segoe UI Emoji, Segoe UI"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="{StaticResource OverlayAccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
                <Button x:Name="MaximizeButton" Width="34" Height="28" Margin="4,0,0,0" Click="MaximizeButton_Click">
                    <TextBlock x:Name="MaximizeIcon"
                               Text="&#x1F5D6;"
                               FontFamily="Segoe UI Symbol, Segoe UI Emoji, Segoe UI"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="{StaticResource OverlayAccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
                <Button Width="34" Height="28" Margin="4,0,0,0" Click="CloseButton_Click">
                    <TextBlock Text="&#x2715;"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="{StaticResource OverlayAccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
