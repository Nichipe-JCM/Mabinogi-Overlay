<Application x:Class="TestOverlay.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:TestOverlay.App"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark"/>
                <ui:ControlsDictionary/>
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="OverlayBgColor">#070707</Color>
            <Color x:Key="OverlayPanelColor">#171717</Color>
            <Color x:Key="OverlayPanelElevatedColor">#202020</Color>
            <Color x:Key="OverlayPanelSoftColor">#101010</Color>
            <Color x:Key="OverlayBorderColor">#343638</Color>
            <Color x:Key="OverlayTextColor">#ECECEC</Color>
            <Color x:Key="OverlayMutedColor">#A7AAAD</Color>
            <Color x:Key="OverlayAccentColor">#89DED4</Color>
            <Color x:Key="OverlayAccentTextColor">#071414</Color>
            <Color x:Key="OverlayBlueColor">#89DED4</Color>
            <Color x:Key="OverlayDangerColor">#FFB4AB</Color>
            <Color x:Key="CandidateCheckColor">#FBBF24</Color>

            <SolidColorBrush x:Key="OverlayBgBrush" Color="{StaticResource OverlayBgColor}"/>
            <SolidColorBrush x:Key="OverlayPanelBrush" Color="{StaticResource OverlayPanelColor}"/>
            <SolidColorBrush x:Key="OverlayPanelElevatedBrush" Color="{StaticResource OverlayPanelElevatedColor}"/>
            <SolidColorBrush x:Key="OverlayPanelSoftBrush" Color="{StaticResource OverlayPanelSoftColor}"/>
            <SolidColorBrush x:Key="OverlayBorderBrush" Color="{StaticResource OverlayBorderColor}"/>
            <SolidColorBrush x:Key="OverlayTextBrush" Color="{StaticResource OverlayTextColor}"/>
            <SolidColorBrush x:Key="OverlayMutedBrush" Color="{StaticResource OverlayMutedColor}"/>
            <SolidColorBrush x:Key="OverlayAccentBrush" Color="{StaticResource OverlayAccentColor}"/>
            <SolidColorBrush x:Key="OverlayAccentTextBrush" Color="{StaticResource OverlayAccentTextColor}"/>
            <SolidColorBrush x:Key="OverlayBlueBrush" Color="{StaticResource OverlayBlueColor}"/>
            <SolidColorBrush x:Key="OverlayDangerBrush" Color="{StaticResource OverlayDangerColor}"/>
            <SolidColorBrush x:Key="CandidateCheckBrush" Color="{StaticResource CandidateCheckColor}"/>

            <Style x:Key="AppWindowRootStyle" TargetType="{x:Type Grid}">
                <Setter Property="Background" Value="{StaticResource OverlayBgBrush}"/>
            </Style>

            <Style x:Key="GlassCardStyle" TargetType="{x:Type Border}">
                <Setter Property="Background" Value="#D9171717"/>
                <Setter Property="BorderBrush" Value="#66343638"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>

            <Style x:Key="CardHeaderStyle" TargetType="{x:Type Border}">
                <Setter Property="Background" Value="#80202020"/>
                <Setter Property="BorderBrush" Value="#55343638"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="Padding" Value="14,12"/>
            </Style>

            <Style x:Key="InsetPanelStyle" TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{StaticResource OverlayPanelSoftBrush}"/>
                <Setter Property="BorderBrush" Value="#55343638"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="12"/>
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{StaticResource OverlayTextBrush}"/>
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            </Style>

            <Style x:Key="PanelTitleStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{StaticResource OverlayTextBrush}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            </Style>

            <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{StaticResource OverlayMutedBrush}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            </Style>

            <Style x:Key="MonoSummaryStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MutedTextStyle}">
                <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
                <Setter Property="FontSize" Value="11"/>
            </Style>

            <Style x:Key="PrimaryActionButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Background" Value="{StaticResource OverlayPanelElevatedBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource OverlayTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource OverlayAccentBrush}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="CandidateListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
                <Setter Property="MinHeight" Value="24"/>
                <Setter Property="Padding" Value="2,0"/>
                <Setter Property="Margin" Value="0,1"/>
                <Setter Property="Foreground" Value="{StaticResource OverlayTextBrush}"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border x:Name="ItemBorder"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#141F2928"/>
                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#33515F5D"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#2A89DED4"/>
                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#AA89DED4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CandidateCheckBoxStyle" TargetType="{x:Type CheckBox}">
                <Setter Property="Foreground" Value="{StaticResource OverlayTextBrush}"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="MinHeight" Value="20"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type CheckBox}">
                            <Grid MinHeight="20" SnapsToDevicePixels="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="CheckBoxBorder"
                                        Width="13"
                                        Height="13"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="#22171717"
                                        BorderBrush="{StaticResource CandidateCheckBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2"/>
                                <Path x:Name="CheckMark"
                                      Data="M 3 6 L 5.4 8.4 L 10 3.5"
                                      Stroke="{StaticResource CandidateCheckBrush}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed"/>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="5,0,0,0"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="CheckBoxBorder" Property="Background" Value="#33FBBF24"/>
                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#FFF59E0B"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DangerTextStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{StaticResource OverlayDangerBrush}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
