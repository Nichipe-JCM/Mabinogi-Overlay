<Window x:Class="TestOverlay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mabinogi Cooldown Overlay"
        Height="920"
        Width="1660"
        MinHeight="760"
        MinWidth="1360"
        Background="#F3F5F7"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyDown="Window_KeyDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="1. Window Capture" FontWeight="SemiBold" Foreground="#20242B"/>
                    <ComboBox x:Name="WindowCombo" Margin="0,8,12,0" Height="34" DisplayMemberPath="DisplayName"/>
                    <TextBlock x:Name="WindowStatusText" Margin="0,6,0,0" Foreground="#596273"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="RefreshWindowsButton" Width="92" Height="34" Margin="8,20,0,0" Content="Refresh" Click="RefreshWindowsButton_Click"/>
                <Button Grid.Column="2" x:Name="VerifyWgcButton" Width="112" Height="34" Margin="8,20,0,0" Content="Verify WGC" Click="VerifyWgcButton_Click"/>
                <Button Grid.Column="3" x:Name="CaptureButton" Width="94" Height="34" Margin="8,20,0,0" Content="Capture" Click="CaptureButton_Click"/>
                <Button Grid.Column="4" x:Name="DetectButton" Width="148" Height="34" Margin="8,20,0,0" Content="Auto detect section" Click="DetectButton_Click"/>
                <Button Grid.Column="5" x:Name="DebugDetectButton" Width="116" Height="34" Margin="8,20,0,0" Content="Debug detect" Click="DebugDetectButton_Click"/>
                <Button Grid.Column="6" x:Name="StopOverlayButton" Width="104" Height="34" Margin="8,20,0,0" Content="Stop" Click="StopOverlayButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="480"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="720" MinWidth="560"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="14" LastChildFill="False">
                        <TextBlock Text="Capture Preview" FontSize="16" FontWeight="SemiBold" Foreground="#20242B"/>
                        <TextBlock x:Name="DetectModeText"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="#B45309"
                                   Visibility="Collapsed"
                                   Text="AUTO DETECT SECTION: drag a section area"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Width="28" Height="24" Margin="0,0,6,0" Content="-" Click="ZoomOutButton_Click"/>
                            <TextBlock Text="Zoom" VerticalAlignment="Center" Foreground="#596273"/>
                            <Slider x:Name="CaptureZoomSlider" Width="140" Minimum="0.25" Maximum="3" Value="1" TickFrequency="0.25" IsSnapToTickEnabled="True" Margin="8,0,8,0" ValueChanged="CaptureZoomSlider_ValueChanged"/>
                            <TextBlock x:Name="CaptureZoomText" Width="44" VerticalAlignment="Center" Foreground="#596273"/>
                            <Button Width="28" Height="24" Margin="6,0,12,0" Content="+" Click="ZoomInButton_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="CaptureInfoText" DockPanel.Dock="Right" Foreground="#596273"/>
                    </DockPanel>
                    <ScrollViewer x:Name="PreviewScrollViewer"
                                  Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#111827"
                                  PreviewKeyDown="PreviewScrollViewer_PreviewKeyDown"
                                  PreviewMouseWheel="PreviewScrollViewer_PreviewMouseWheel">
                        <Canvas x:Name="CaptureCanvas"
                                Focusable="True"
                                Background="#111827"
                                MouseLeftButtonDown="CaptureCanvas_MouseLeftButtonDown"
                                MouseMove="CaptureCanvas_MouseMove"
                                MouseLeftButtonUp="CaptureCanvas_MouseLeftButtonUp">
                            <Canvas.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding ElementName=CaptureZoomSlider, Path=Value}" ScaleY="{Binding ElementName=CaptureZoomSlider, Path=Value}"/>
                            </Canvas.LayoutTransform>
                            <Image x:Name="CaptureImage" Stretch="None"/>
                        </Canvas>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          Margin="3,0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Background="#CBD5E1"
                          Cursor="SizeWE"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.35*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="0.75*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="2. Slot Candidates" FontSize="16" FontWeight="SemiBold" Foreground="#20242B"/>

                        <Expander Grid.Row="1" Header="Create manual section" IsExpanded="False" Margin="0,12,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Text="Slot size"/>
                                <WrapPanel>
                                    <TextBlock Text="W" VerticalAlignment="Center"/>
                                    <TextBox x:Name="SlotWidthBox" Width="64" Height="24" Margin="6,0,14,0" Text="29" TextChanged="SlotSizeBox_TextChanged"/>
                                    <TextBlock Text="H" VerticalAlignment="Center"/>
                                    <TextBox x:Name="SlotHeightBox" Width="64" Height="24" Margin="6,0,0,0" Text="29" TextChanged="SlotSizeBox_TextChanged"/>
                                    <Button x:Name="ApplySlotSizeButton" Width="64" Height="24" Margin="10,0,0,0" Content="Apply" Click="ApplySlotSizeButton_Click"/>
                                </WrapPanel>
                                <TextBlock x:Name="SlotSizeText"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="Section pattern"/>
                                <ComboBox x:Name="SectionPatternCombo" SelectedIndex="0">
                                    <ComboBoxItem Content="Top grouped 4x2 x3"/>
                                    <ComboBoxItem Content="Vertical 2x8"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="Section"/>
                                <ComboBox x:Name="SectionCombo" Height="28" DisplayMemberPath="Label" SelectionChanged="SectionCombo_SelectionChanged"/>
                                <WrapPanel Margin="0,6,0,0">
                                    <Button x:Name="AddSectionFromSelectedButton" Width="112" Height="28" Content="Add Section" Click="AddSectionFromSelectedButton_Click"/>
                                    <Button x:Name="DeleteSectionButton" Width="76" Height="28" Margin="6,0,0,0" Content="Delete" Click="DeleteSectionButton_Click"/>
                                </WrapPanel>
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="0">
                                <TextBlock x:Name="SmallGapXText"/>
                                <Slider x:Name="SmallGapXSlider" Minimum="2" Maximum="30" Value="2" TickFrequency="1" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="2">
                                <TextBlock x:Name="SmallGapYText"/>
                                <Slider x:Name="SmallGapYSlider" Minimum="2" Maximum="30" Value="2" TickFrequency="1" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                            <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock x:Name="LargeGapText"/>
                                <Slider x:Name="LargeGapSlider" Minimum="2" Maximum="60" Value="16" TickFrequency="1" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                        </Grid>
                        </Expander>

                        <ListBox Grid.Row="2"
                                 x:Name="CandidateList"
                                 ItemsSource="{Binding Candidates}"
                                 BorderBrush="#D9DEE7"
                                 MinHeight="120"
                                 KeyDown="CandidateList_KeyDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Content="{Binding Label}" Margin="4"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button x:Name="SelectAllCandidatesButton" Width="70" Height="32" Margin="4,0,0,0" Content="All" Click="SelectAllCandidatesButton_Click"/>
                            <Button x:Name="DeselectAllCandidatesButton" Width="70" Height="32" Margin="4,0,0,0" Content="None" Click="DeselectAllCandidatesButton_Click"/>
                            <Button x:Name="AddManualCandidateButton" Width="82" Height="32" Margin="4,0,0,0" Content="Add" Click="AddManualCandidateButton_Click"/>
                            <Button x:Name="DeleteSelectedCandidatesButton" Width="82" Height="32" Margin="4,0,0,0" Content="Delete" Click="DeleteSelectedCandidatesButton_Click"/>
                            <Button x:Name="AddToOverlayButton" Width="118" Height="32" Margin="4,0,0,0" Content="Add to overlay" Click="AddToOverlayButton_Click"/>
                            <Button x:Name="ClearCandidatesButton" Width="72" Height="32" Margin="4,0,0,0" Content="Clear" Click="ClearCandidatesButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="3. Overlay Layout" FontSize="16" FontWeight="SemiBold" Foreground="#20242B"/>

                        <Border Grid.Row="1" Margin="0,12,0,12" Padding="12" BorderBrush="#D9DEE7" BorderThickness="1" Background="#F8FAFC">
                            <StackPanel>
                                <TextBlock x:Name="LayoutSummaryText" Foreground="#20242B" TextWrapping="Wrap"/>
                                <TextBlock Margin="0,8,0,0" Foreground="#596273" TextWrapping="Wrap"
                                           Text="Use the layout editor to size the canvas, arrange slots, set screen position, opacity, scale, hotkey, and refresh interval."/>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="OpenLayoutEditorButton" Width="126" Height="34" Margin="4,0,0,0" Content="Manage Layout" Click="OpenLayoutEditorButton_Click"/>
                            <Button x:Name="ClearLayoutButton" Width="66" Height="34" Margin="4,0,0,0" Content="Clear" Click="ClearLayoutButton_Click"/>
                            <Button x:Name="StartOverlayButton" Width="62" Height="34" Margin="4,0,0,0" Content="Start" Click="StartOverlayButton_Click"/>
                            <Button x:Name="StopOverlayLayoutButton" Width="62" Height="34" Margin="4,0,0,0" Content="Stop" Click="StopOverlayButton_Click"/>
                            <Button x:Name="SettingsButton" Width="112" Height="34" Margin="4,0,0,0" Content="Settings" Click="SettingsButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Foreground="#596273"
                   Text="The base UI is not topmost. The overlay is click-through. Configure the stop hotkey before Start."/>
    </Grid>
</Window>
