<Window x:Class="TestOverlay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mabinogi Cooldown Overlay MVP"
        Height="920"
        Width="1360"
        MinHeight="760"
        MinWidth="1120"
        Background="#F3F5F7">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="14" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Game Window" FontWeight="SemiBold" Foreground="#20242B"/>
                    <ComboBox x:Name="WindowCombo" Margin="0,8,12,0" Height="34" DisplayMemberPath="DisplayName"/>
                    <TextBlock x:Name="WindowStatusText" Margin="0,6,0,0" Foreground="#596273"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="RefreshWindowsButton" Width="110" Height="36" Margin="8,20,0,0" Content="Refresh" Click="RefreshWindowsButton_Click"/>
                <Button Grid.Column="2" x:Name="VerifyWgcButton" Width="120" Height="36" Margin="8,20,0,0" Content="Verify WGC" Click="VerifyWgcButton_Click"/>
                <Button Grid.Column="3" x:Name="CaptureButton" Width="110" Height="36" Margin="8,20,0,0" Content="Capture" Click="CaptureButton_Click"/>
                <Button Grid.Column="4" x:Name="DetectButton" Width="120" Height="36" Margin="8,20,0,0" Content="Detect Slots" Click="DetectButton_Click"/>
                <Button Grid.Column="5" x:Name="StopOverlayButton" Width="120" Height="36" Margin="8,20,0,0" Content="Stop Overlay" Click="StopOverlayButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="450"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="14">
                        <TextBlock Text="Capture and Slot Candidates" FontSize="16" FontWeight="SemiBold" Foreground="#20242B"/>
                        <TextBlock x:Name="CaptureInfoText" DockPanel.Dock="Right" Foreground="#596273"/>
                    </DockPanel>
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#111827">
                        <Canvas x:Name="CaptureCanvas" Background="#111827" MouseLeftButtonDown="CaptureCanvas_MouseLeftButtonDown">
                            <Image x:Name="CaptureImage" Stretch="None"/>
                        </Canvas>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.05*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="1.05*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Detection and Calibration" FontSize="16" FontWeight="SemiBold" Foreground="#20242B"/>

                        <Grid Grid.Row="1" Margin="0,12,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Min slot size"/>
                                <Slider x:Name="MinSlotSizeSlider" Minimum="16" Maximum="80" Value="24" TickFrequency="2" IsSnapToTickEnabled="True"/>
                                <TextBlock x:Name="MinSlotSizeText"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Max slot size"/>
                                <Slider x:Name="MaxSlotSizeSlider" Minimum="24" Maximum="96" Value="64" TickFrequency="2" IsSnapToTickEnabled="True"/>
                                <TextBlock x:Name="MaxSlotSizeText"/>
                            </StackPanel>
                        </Grid>

                        <ListBox Grid.Row="2" x:Name="CandidateList" ItemsSource="{Binding Candidates}" BorderBrush="#D9DEE7">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Content="{Binding Label}" Margin="4"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button x:Name="AddSelectedButton" Width="150" Height="34" Content="Place Selected" Click="AddSelectedButton_Click"/>
                            <Button x:Name="ClearCandidatesButton" Width="120" Height="34" Margin="8,0,0,0" Content="Clear" Click="ClearCandidatesButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Overlay Canvas" FontSize="16" FontWeight="SemiBold" Foreground="#20242B"/>

                        <Grid Grid.Row="1" Margin="0,12,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Width"/>
                                <TextBox x:Name="OverlayWidthBox" Text="360"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,8,0">
                                <TextBlock Text="Height"/>
                                <TextBox x:Name="OverlayHeightBox" Text="160"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="Opacity"/>
                                <Slider x:Name="OpacitySlider" Minimum="0.2" Maximum="1" Value="0.8" TickFrequency="0.05"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Screen X"/>
                                <TextBox x:Name="OverlayLeftBox" Text="120"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,8,0">
                                <TextBlock Text="Screen Y"/>
                                <TextBox x:Name="OverlayTopBox" Text="120"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="Stop hotkey"/>
                                <TextBox x:Name="HotkeyBox" Text="Ctrl+Shift+F8"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="3" Margin="8,0,0,0">
                                <TextBlock Text="Refresh ms"/>
                                <TextBox x:Name="RefreshIntervalBox" Text="500"/>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2" BorderBrush="#2F3645" BorderThickness="1" Background="#202633">
                            <Canvas x:Name="LayoutCanvas" Width="360" Height="160" Background="#202633"
                                    MouseLeftButtonUp="LayoutCanvas_MouseLeftButtonUp"
                                    MouseMove="LayoutCanvas_MouseMove"/>
                        </Border>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button x:Name="UseDefaultOverlayPositionButton" Width="100" Height="34" Content="Default Pos" Click="UseDefaultOverlayPositionButton_Click"/>
                            <Button x:Name="ApplyCanvasButton" Width="110" Height="34" Margin="8,0,0,0" Content="Apply" Click="ApplyCanvasButton_Click"/>
                            <Button x:Name="SaveProfileButton" Width="100" Height="34" Margin="8,0,0,0" Content="Save" Click="SaveProfileButton_Click"/>
                            <Button x:Name="LoadProfileButton" Width="100" Height="34" Margin="8,0,0,0" Content="Load" Click="LoadProfileButton_Click"/>
                            <Button x:Name="StartOverlayButton" Width="100" Height="34" Margin="8,0,0,0" Content="Start" Click="StartOverlayButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Foreground="#596273"
                   Text="The base UI is not topmost. The overlay is click-through. Configure the stop hotkey before Start."/>
    </Grid>
</Window>
