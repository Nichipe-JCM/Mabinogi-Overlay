<Window x:Class="TestOverlay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mabinogi Overlay"
        Height="920"
        Width="1660"
        MinHeight="760"
        MinWidth="1360"
        Background="{StaticResource OverlayBgBrush}"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyDown="Window_KeyDown">
    <Grid Margin="18" Style="{StaticResource AppWindowRootStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="34"
                            Height="34"
                            Background="#1EFFFFFF"
                            BorderBrush="#35FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Image Source="/Image/Logo.png"
                               Width="28"
                               Height="28"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Stretch="Uniform"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Mabinogi Overlay" FontSize="17" FontWeight="Bold" Foreground="{StaticResource OverlayAccentBrush}"/>
                        <TextBlock Text="Management dashboard" Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="210"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CaptureBackendCombo"
                                  Grid.Column="0"
                                  Height="36"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="CaptureBackendCombo_SelectionChanged"/>
                        <ComboBox x:Name="WindowCombo"
                                  Grid.Column="2"
                                  Height="36"
                                  DisplayMemberPath="DisplayName"
                                  SelectionChanged="WindowCombo_SelectionChanged"/>
                    </Grid>
                    <TextBlock x:Name="WindowStatusText" Margin="0,6,0,0" Style="{StaticResource MutedTextStyle}" Visibility="Collapsed"/>
                </StackPanel>

                <WrapPanel Grid.Column="3" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Button x:Name="RefreshWindowsButton" Width="92" Height="36" Margin="6,0,0,0" Content="Refresh" Click="RefreshWindowsButton_Click"/>
                    <Button x:Name="AutoCaptureButton" Width="112" Height="36" Margin="6,0,0,0" Content="Auto capture" Click="AutoCaptureButton_Click"/>
                    <Button x:Name="ManualCaptureButton" Width="124" Height="36" Margin="6,0,0,0" Content="Manual capture" Click="ManualCaptureButton_Click"/>
                    <Button x:Name="DetectButton" Width="150" Height="36" Margin="6,0,0,0" Content="Auto detect section" Click="DetectButton_Click"/>
                    <Button x:Name="DebugDetectButton" Width="116" Height="36" Margin="6,0,0,0" Content="Debug detect" Click="DebugDetectButton_Click"/>
                    <Button x:Name="StopOverlayButton" Width="88" Height="36" Margin="6,0,0,0" Content="Stop" Click="StopOverlayButton_Click"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="520"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="720" MinWidth="560"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardHeaderStyle}">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Capture Preview" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="DetectModeText"
                                           Margin="0,4,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource OverlayAccentBrush}"
                                           Visibility="Collapsed"
                                           Text="AUTO DETECT SECTION: drag a section area"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="CaptureInfoText" VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}"/>
                                <Button Width="28" Height="26" Margin="12,0,6,0" Content="-" Click="ZoomOutButton_Click"/>
                                <TextBlock Text="Zoom" VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}"/>
                                <Slider x:Name="CaptureZoomSlider"
                                        Width="140"
                                        Minimum="0.25"
                                        Maximum="3"
                                        Value="1"
                                        TickFrequency="0.25"
                                        IsSnapToTickEnabled="True"
                                        Margin="8,0"
                                        ValueChanged="CaptureZoomSlider_ValueChanged"/>
                                <TextBlock x:Name="CaptureZoomText" Width="46" VerticalAlignment="Center" Style="{StaticResource MonoSummaryStyle}"/>
                                <Button Width="28" Height="26" Margin="6,0,0,0" Content="+" Click="ZoomInButton_Click"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ScrollViewer x:Name="PreviewScrollViewer"
                                  Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="{StaticResource OverlayBgBrush}"
                                  PreviewKeyDown="PreviewScrollViewer_PreviewKeyDown"
                                  PreviewMouseWheel="PreviewScrollViewer_PreviewMouseWheel">
                        <Canvas x:Name="CaptureCanvas"
                                Focusable="True"
                                Background="{StaticResource OverlayBgBrush}"
                                MouseLeftButtonDown="CaptureCanvas_MouseLeftButtonDown"
                                MouseMove="CaptureCanvas_MouseMove"
                                MouseLeftButtonUp="CaptureCanvas_MouseLeftButtonUp">
                            <Canvas.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding ElementName=CaptureZoomSlider, Path=Value}" ScaleY="{Binding ElementName=CaptureZoomSlider, Path=Value}"/>
                            </Canvas.LayoutTransform>
                            <Image x:Name="CaptureImage" Stretch="None"/>
                        </Canvas>
                    </ScrollViewer>

                    <Border Grid.Row="2" Padding="12,8" Background="#55101010" BorderBrush="#44343638" BorderThickness="0,1,0,0">
                        <TextBlock Text="Drag to select slots or sections. Use Ctrl/Shift for multi-select and mouse wheel for zoom." Style="{StaticResource MutedTextStyle}"/>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          Margin="3,0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Background="{StaticResource OverlayBorderBrush}"
                          Cursor="SizeWE"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.35*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="0.8*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardHeaderStyle}">
                            <TextBlock Text="2. Slot Candidates" Style="{StaticResource SectionTitleStyle}"/>
                        </Border>

                        <Expander Grid.Row="1" Header="Create manual section" IsExpanded="False" Margin="14,12,14,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                                    <TextBlock Text="Slot size" Style="{StaticResource PanelTitleStyle}"/>
                                    <WrapPanel Margin="0,6,0,0">
                                        <TextBlock Text="W" VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}"/>
                                        <TextBox x:Name="SlotWidthBox" Width="64" Height="28" Margin="6,0,14,0" Text="29" TextChanged="SlotSizeBox_TextChanged"/>
                                        <TextBlock Text="H" VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}"/>
                                        <TextBox x:Name="SlotHeightBox" Width="64" Height="28" Margin="6,0,0,0" Text="29" TextChanged="SlotSizeBox_TextChanged"/>
                                        <Button x:Name="ApplySlotSizeButton" Width="70" Height="28" Margin="10,0,0,0" Content="Apply" Click="ApplySlotSizeButton_Click"/>
                                    </WrapPanel>
                                    <TextBlock x:Name="SlotSizeText" Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="Section pattern" Style="{StaticResource PanelTitleStyle}"/>
                                    <ComboBox x:Name="SectionPatternCombo" Height="30" Margin="0,6,0,0" SelectedIndex="0">
                                        <ComboBoxItem Content="Top grouped 4x2 x3"/>
                                        <ComboBoxItem Content="Vertical 2x8"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Text="Section" Style="{StaticResource PanelTitleStyle}"/>
                                    <ComboBox x:Name="SectionCombo" Height="30" Margin="0,6,0,0" DisplayMemberPath="Label" SelectionChanged="SectionCombo_SelectionChanged"/>
                                    <WrapPanel Margin="0,6,0,0">
                                        <Button x:Name="AddSectionFromSelectedButton" Width="112" Height="28" Content="Add Section" Click="AddSectionFromSelectedButton_Click"/>
                                        <Button x:Name="DeleteSectionButton" Width="76" Height="28" Margin="6,0,0,0" Content="Delete" Click="DeleteSectionButton_Click"/>
                                    </WrapPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="4" Grid.Column="0">
                                    <TextBlock x:Name="SmallGapXText" Style="{StaticResource MutedTextStyle}"/>
                                    <Slider x:Name="SmallGapXSlider" Minimum="2" Maximum="30" Value="2" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="2">
                                    <TextBlock x:Name="SmallGapYText" Style="{StaticResource MutedTextStyle}"/>
                                    <Slider x:Name="SmallGapYSlider" Minimum="2" Maximum="30" Value="2" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                </StackPanel>
                                <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                                    <TextBlock x:Name="LargeGapText" Style="{StaticResource MutedTextStyle}"/>
                                    <Slider x:Name="LargeGapSlider" Minimum="2" Maximum="60" Value="16" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                </StackPanel>
                            </Grid>
                        </Expander>

                        <ListBox Grid.Row="2"
                                 x:Name="CandidateList"
                                 Margin="14,0"
                                 ItemsSource="{Binding Candidates}"
                                 MinHeight="120"
                                 FontSize="12"
                                 ItemContainerStyle="{StaticResource CandidateListBoxItemStyle}"
                                 KeyDown="CandidateList_KeyDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Content="{Binding Label}"
                                              Style="{StaticResource CandidateCheckBoxStyle}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <WrapPanel Grid.Row="3" HorizontalAlignment="Right" Margin="14,12,14,14">
                            <Button x:Name="SelectAllCandidatesButton" Width="68" Height="32" Margin="4,0,0,0" Content="All" Click="SelectAllCandidatesButton_Click"/>
                            <Button x:Name="DeselectAllCandidatesButton" Width="72" Height="32" Margin="4,0,0,0" Content="None" Click="DeselectAllCandidatesButton_Click"/>
                            <Button x:Name="AddManualCandidateButton" Width="72" Height="32" Margin="4,0,0,0" Content="Add" Click="AddManualCandidateButton_Click"/>
                            <Button x:Name="DeleteSelectedCandidatesButton" Width="82" Height="32" Margin="4,0,0,0" Content="Delete" Click="DeleteSelectedCandidatesButton_Click"/>
                            <Button x:Name="AddToOverlayButton" Width="118" Height="32" Margin="4,0,0,0" Content="Add to overlay" Click="AddToOverlayButton_Click"/>
                            <Button x:Name="ClearCandidatesButton" Width="72" Height="32" Margin="4,0,0,0" Content="Clear" Click="ClearCandidatesButton_Click"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource GlassCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardHeaderStyle}">
                            <TextBlock Text="3. Overlay Layout" Style="{StaticResource SectionTitleStyle}"/>
                        </Border>

                        <Border Grid.Row="1" Margin="14,12" Style="{StaticResource InsetPanelStyle}">
                            <StackPanel>
                                <TextBlock x:Name="LayoutSummaryText" Style="{StaticResource MonoSummaryStyle}"/>
                                <TextBlock Margin="0,8,0,0"
                                           Text="Use the layout editor to size the canvas, arrange slots, set screen position, opacity, scale, hotkey, and refresh interval."
                                           Style="{StaticResource MutedTextStyle}"/>
                            </StackPanel>
                        </Border>

                        <WrapPanel Grid.Row="2" HorizontalAlignment="Right" Margin="14,0,14,14">
                            <Button x:Name="OpenLayoutEditorButton" Width="126" Height="34" Margin="4,0,0,0" Content="Manage Layout" Click="OpenLayoutEditorButton_Click"/>
                            <Button x:Name="ClearLayoutButton" Width="66" Height="34" Margin="4,0,0,0" Content="Clear" Click="ClearLayoutButton_Click"/>
                            <Button x:Name="StartOverlayButton" Width="68" Height="34" Margin="4,0,0,0" Content="Start" Click="StartOverlayButton_Click"/>
                            <Button x:Name="StopOverlayLayoutButton" Width="62" Height="34" Margin="4,0,0,0" Content="Stop" Click="StopOverlayButton_Click"/>
                            <Button x:Name="SettingsButton" Width="112" Height="34" Margin="4,0,0,0" Content="Settings" Click="SettingsButton_Click"/>
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Padding="12,8" Style="{StaticResource GlassCardStyle}">
            <TextBlock x:Name="StatusText"
                       Style="{StaticResource MutedTextStyle}"
                       Text="The base UI is not topmost. The overlay is click-through. Configure the stop hotkey before Start."/>
        </Border>
    </Grid>
</Window>
