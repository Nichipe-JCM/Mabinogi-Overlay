<Window x:Class="TestOverlay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TestOverlay.App.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Mabinogi Overlay"
        loc:Localize.TitleKey="Mabinogi Overlay"
        Icon="/Image/AppIcon.ico"
        Height="1000"
        Width="1660"
        MinHeight="840"
        MinWidth="1360"
        Background="{StaticResource OverlayBgBrush}"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyDown="Window_KeyDown"
        StateChanged="Window_StateChanged">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="7"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid Margin="8,4,8,8" Style="{StaticResource AppWindowRootStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,8"
                Style="{StaticResource GlassCardStyle}"
                PreviewMouseLeftButtonDown="TitleBarArea_PreviewMouseLeftButtonDown">
            <Grid Height="42" Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0"
                       Source="/Image/Logo.png"
                       Width="24"
                       Height="24"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Grid.Column="1"
                           Text="Mabinogi Overlay"
                           loc:Localize.TextKey="Mabinogi Overlay"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource OverlayAccentBrush}"/>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Width="34" Height="28" Margin="4,0,0,0" Click="MinimizeWindowButton_Click">
                        <TextBlock Text="&#x1F5D5;"
                                   FontFamily="Segoe UI Symbol, Segoe UI Emoji, Segoe UI"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OverlayAccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="MaximizeWindowButton" Width="34" Height="28" Margin="4,0,0,0" Click="MaximizeWindowButton_Click">
                        <TextBlock x:Name="MaximizeWindowIcon"
                                   Text="&#x1F5D6;"
                                   FontFamily="Segoe UI Symbol, Segoe UI Emoji, Segoe UI"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OverlayAccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button Width="34" Height="28" Margin="4,0,0,0" Click="CloseWindowButton_Click">
                        <TextBlock Text="&#x2715;"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OverlayAccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource GlassCardStyle}">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="51"
                            Height="51"
                            Background="#1EFFFFFF"
                            BorderBrush="#35FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Image Source="/Image/Logo.png"
                               Width="42"
                               Height="42"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Mabinogi Overlay" FontSize="17" FontWeight="Bold" Foreground="{StaticResource OverlayAccentBrush}"/>
                        <TextBlock Text="v0.0.2-beta" Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <ComboBox x:Name="WindowCombo"
                              Height="36"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="WindowCombo_SelectionChanged"/>
                    <TextBlock x:Name="WindowStatusText" Margin="0,6,0,0" Style="{StaticResource MutedTextStyle}" Visibility="Collapsed"/>
                </StackPanel>

                <WrapPanel Grid.Column="3" Margin="16,0,0,0" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="RefreshWindowsButton" MinWidth="92" Height="36" Padding="14,0" Margin="6,0,0,0" Content="Refresh" loc:Localize.ContentKey="Refresh" Click="RefreshWindowsButton_Click"/>
                    <Button x:Name="AutoCaptureButton" MinWidth="112" Height="36" Padding="14,0" Margin="6,0,0,0" Content="Auto capture" loc:Localize.ContentKey="Auto capture" Click="AutoCaptureButton_Click"/>
                    <Button x:Name="ManualCaptureButton" MinWidth="124" Height="36" Padding="14,0" Margin="6,0,0,0" Content="Manual capture" loc:Localize.ContentKey="Manual capture" Click="ManualCaptureButton_Click"/>
                    <Button x:Name="DetectButton" MinWidth="150" Height="36" Padding="14,0" Margin="6,0,0,0" Content="Auto detect section" loc:Localize.ContentKey="Auto detect section" Click="DetectButton_Click"/>
                    <Button x:Name="DebugDetectButton" MinWidth="116" Height="36" Padding="14,0" Margin="6,0,0,0" Content="Debug detect" loc:Localize.ContentKey="Debug detect" Click="DebugDetectButton_Click"/>
                    <Button x:Name="SettingsButton" MinWidth="112" Height="36" Padding="14,0" Margin="6,0,0,0" Content="Settings" loc:Localize.ContentKey="Settings" Click="SettingsButton_Click"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}">
                <Grid Margin="16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Margin="0,0,18,0"
                               VerticalAlignment="Center"
                               Text="Profile"
                               loc:Localize.TextKey="Profile"
                               Style="{StaticResource SectionTitleStyle}"/>
                    <ComboBox x:Name="ProfileCombo"
                              Grid.Column="1"
                              MinWidth="180"
                              Height="36"
                              SelectionChanged="ProfileCombo_SelectionChanged"/>
                    <Button x:Name="CreateProfileButton" Grid.Column="2" MinWidth="92" Height="36" Padding="14,0" Margin="8,0,0,0" Content="Create" loc:Localize.ContentKey="profile.create" Click="CreateProfileButton_Click"/>
                    <Button x:Name="LoadProfileButton" Grid.Column="3" MinWidth="92" Height="36" Padding="14,0" Margin="8,0,0,0" Content="Load" loc:Localize.ContentKey="Load" Click="LoadProfileButton_Click"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource GlassCardStyle}">
                <Grid Margin="16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="Overlay controls"
                               loc:Localize.TextKey="overlay.controls"
                               Style="{StaticResource SectionTitleStyle}"/>
                    <Button x:Name="StartOverlayButton" Grid.Column="1" MinWidth="132" Height="36" Padding="14,0" Margin="8,0,0,0" Content="Overlay start" loc:Localize.ContentKey="Overlay start" Click="StartOverlayButton_Click"/>
                    <Button x:Name="StopOverlayLayoutButton" Grid.Column="2" MinWidth="132" Height="36" Padding="14,0" Margin="8,0,0,0" Content="Overlay stop" loc:Localize.ContentKey="Overlay stop" Click="StopOverlayButton_Click"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="520"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="720" MinWidth="560"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardHeaderStyle}">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Capture Preview" loc:Localize.TextKey="Capture Preview" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="DetectModeText"
                                           Margin="0,4,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource OverlayAccentBrush}"
                                           Visibility="Collapsed"
                                           Text="AUTO DETECT SECTION: drag a section area"
                                           loc:Localize.TextKey="AUTO DETECT SECTION: drag a section area"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="CaptureInfoText" VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}"/>
                                <Button Width="28" Height="26" Margin="12,0,6,0" Content="-" Click="ZoomOutButton_Click"/>
                                <TextBlock Text="Zoom" loc:Localize.TextKey="Zoom" VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}"/>
                                <Slider x:Name="CaptureZoomSlider"
                                        Width="140"
                                        Minimum="0.25"
                                        Maximum="3"
                                        Value="1"
                                        TickFrequency="0.25"
                                        IsSnapToTickEnabled="True"
                                        Margin="8,0"
                                        ValueChanged="CaptureZoomSlider_ValueChanged"/>
                                <TextBlock x:Name="CaptureZoomText" Width="46" VerticalAlignment="Center" Style="{StaticResource MonoSummaryStyle}"/>
                                <Button Width="28" Height="26" Margin="6,0,0,0" Content="+" Click="ZoomInButton_Click"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1" Background="{StaticResource OverlayBgBrush}">
                        <ScrollViewer x:Name="PreviewScrollViewer"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      Background="{StaticResource OverlayBgBrush}"
                                      PreviewKeyDown="PreviewScrollViewer_PreviewKeyDown"
                                      PreviewMouseWheel="PreviewScrollViewer_PreviewMouseWheel">
                            <Canvas x:Name="CaptureCanvas"
                                    Focusable="True"
                                    Background="{StaticResource OverlayBgBrush}"
                                    MouseLeftButtonDown="CaptureCanvas_MouseLeftButtonDown"
                                    MouseMove="CaptureCanvas_MouseMove"
                                    MouseLeftButtonUp="CaptureCanvas_MouseLeftButtonUp"
                                    MouseRightButtonDown="CaptureCanvas_MouseRightButtonDown">
                                <Canvas.LayoutTransform>
                                    <ScaleTransform ScaleX="{Binding ElementName=CaptureZoomSlider, Path=Value}" ScaleY="{Binding ElementName=CaptureZoomSlider, Path=Value}"/>
                                </Canvas.LayoutTransform>
                                <Image x:Name="CaptureImage" Stretch="None"/>
                            </Canvas>
                        </ScrollViewer>

                        <Border x:Name="CapturePlaceholder"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                BorderBrush="#36434648"
                                BorderThickness="1"
                                Background="#221A1C1E">
                            <Grid>
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="32"
                                            Opacity="0.72">
                                    <Viewbox Width="40" Height="40" HorizontalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Path Stroke="{StaticResource OverlayAccentBrush}"
                                                  StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent"
                                                  Data="M4,7 L8,7 L9.6,5 L14.4,5 L16,7 L20,7 C21.1,7 22,7.9 22,9 L22,18 C22,19.1 21.1,20 20,20 L4,20 C2.9,20 2,19.1 2,18 L2,9 C2,7.9 2.9,7 4,7 Z"/>
                                            <Ellipse Canvas.Left="8"
                                                     Canvas.Top="10"
                                                     Width="8"
                                                     Height="8"
                                                     Stroke="{StaticResource OverlayAccentBrush}"
                                                     StrokeThickness="1.7"
                                                     Fill="Transparent"/>
                                            <Ellipse Canvas.Left="17"
                                                     Canvas.Top="9"
                                                     Width="1.8"
                                                     Height="1.8"
                                                     Fill="{StaticResource OverlayAccentBrush}"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Margin="0,14,0,0"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="#B9C0C4"
                                               Text="Waiting for capture..."
                                               loc:Localize.TextKey="Waiting for capture..."/>
                                    <TextBlock Margin="0,6,0,0"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource OverlayMutedBrush}"
                                               Text="Run Auto capture or Manual capture."
                                               loc:Localize.TextKey="Run Auto capture or Manual capture."/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Padding="12,8" Background="#55101010" BorderBrush="#44343638" BorderThickness="0,1,0,0">
                        <TextBlock Text="Drag to select slots or sections. Use Ctrl/Shift for multi-select and mouse wheel for zoom." loc:Localize.TextKey="Drag to select slots or sections. Use Ctrl/Shift for multi-select and mouse wheel for zoom." Style="{StaticResource MutedTextStyle}"/>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          Margin="3,0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Background="{StaticResource OverlayBorderBrush}"
                          Cursor="SizeWE"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.35*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="0.8*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}">
                    <Grid x:Name="CandidatePanelGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardHeaderStyle}">
                            <TextBlock Text="Slot Candidates" loc:Localize.TextKey="Slot Candidates" Style="{StaticResource SectionTitleStyle}"/>
                        </Border>

                        <ToggleButton x:Name="ManualSectionToggle"
                                      Grid.Row="1"
                                      Margin="14,12,14,10"
                                      Height="38"
                                      Content="Create manual section"
                                      loc:Localize.ContentKey="Create manual section"
                                      Style="{StaticResource ManualSectionToggleStyle}"/>
                        <Popup x:Name="ManualSectionPopup"
                               PlacementTarget="{Binding ElementName=ManualSectionToggle}"
                               Placement="Bottom"
                               IsOpen="{Binding ElementName=ManualSectionToggle, Path=IsChecked, Mode=TwoWay}"
                               StaysOpen="True"
                               AllowsTransparency="True">
                            <Border Width="{Binding ElementName=CandidatePanelGrid, Path=ActualWidth}"
                                    MaxWidth="720"
                                    Margin="14,0,14,0"
                                    Style="{StaticResource GlassCardStyle}">
                                <Grid Margin="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                                        <TextBlock Text="Slot size" loc:Localize.TextKey="Slot size" Style="{StaticResource PanelTitleStyle}"/>
                                        <WrapPanel Margin="0,8,0,0">
                                            <TextBlock Text="W" loc:Localize.TextKey="W" VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}"/>
                                            <TextBox x:Name="SlotWidthBox" Width="74" Height="34" Margin="6,0,14,0" Text="29" TextChanged="SlotSizeBox_TextChanged"/>
                                            <TextBlock Text="H" loc:Localize.TextKey="H" VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}"/>
                                            <TextBox x:Name="SlotHeightBox" Width="74" Height="34" Margin="6,0,0,0" Text="29" TextChanged="SlotSizeBox_TextChanged"/>
                                            <Button x:Name="ApplySlotSizeButton" MinWidth="70" Height="34" Padding="12,0" Margin="10,0,0,0" Content="Apply" loc:Localize.ContentKey="Apply" Click="ApplySlotSizeButton_Click"/>
                                        </WrapPanel>
                                        <TextBlock x:Name="SlotSizeText" Margin="0,6,0,0" Style="{StaticResource MutedTextStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <TextBlock Text="Section pattern" loc:Localize.TextKey="Section pattern" Style="{StaticResource PanelTitleStyle}"/>
                                        <ComboBox x:Name="SectionPatternCombo" Height="38" Margin="0,8,0,0" SelectedIndex="0">
                                            <ComboBoxItem Content="Top grouped 4x2 x3" loc:Localize.ContentKey="Top grouped 4x2 x3"/>
                                            <ComboBoxItem Content="Vertical 2x8" loc:Localize.ContentKey="Vertical 2x8"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="2">
                                        <TextBlock Text="Section" loc:Localize.TextKey="Section" Style="{StaticResource PanelTitleStyle}"/>
                                        <ComboBox x:Name="SectionCombo" Height="38" Margin="0,8,0,0" DisplayMemberPath="Label" SelectionChanged="SectionCombo_SelectionChanged"/>
                                        <WrapPanel Margin="0,8,0,0">
                                            <Button x:Name="AddSectionFromSelectedButton" MinWidth="112" Height="34" Padding="12,0" Content="Add Section" loc:Localize.ContentKey="Add Section" Click="AddSectionFromSelectedButton_Click"/>
                                            <Button x:Name="DeleteSectionButton" MinWidth="76" Height="34" Padding="12,0" Margin="6,0,0,0" Content="Delete" loc:Localize.ContentKey="Delete" Click="DeleteSectionButton_Click"/>
                                        </WrapPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Grid.Column="0">
                                        <TextBlock x:Name="SmallGapXText" Style="{StaticResource MutedTextStyle}"/>
                                        <Slider x:Name="SmallGapXSlider" Minimum="2" Maximum="30" Value="2" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="4" Grid.Column="2">
                                        <TextBlock x:Name="SmallGapYText" Style="{StaticResource MutedTextStyle}"/>
                                        <Slider x:Name="SmallGapYSlider" Minimum="2" Maximum="30" Value="2" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                                        <TextBlock x:Name="LargeGapText" Style="{StaticResource MutedTextStyle}"/>
                                        <Slider x:Name="LargeGapSlider" Minimum="2" Maximum="60" Value="16" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Popup>
                        <Border Grid.Row="2"
                                Margin="14,0"
                                MinHeight="120"
                                Style="{StaticResource InsetPanelStyle}">
                            <ListBox x:Name="CandidateList"
                                     ItemsSource="{Binding Candidates}"
                                     FontSize="12"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemContainerStyle="{StaticResource CandidateListBoxItemStyle}"
                                     KeyDown="CandidateList_KeyDown">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Style="{StaticResource CandidateCheckBoxStyle}"/>
                                            <TextBlock Grid.Column="1"
                                                       Margin="5,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource OverlayTextBrush}"
                                                       Text="{Binding Label}"
                                                       MouseLeftButtonDown="CandidateLabel_MouseLeftButtonDown"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <WrapPanel Grid.Row="3" HorizontalAlignment="Right" Margin="14,12,14,14">
                            <Button x:Name="SelectAllCandidatesButton" MinWidth="96" Height="32" Padding="12,0" Margin="4,0,0,0" Content="Select all" loc:Localize.ContentKey="Select all" Click="SelectAllCandidatesButton_Click"/>
                            <Button x:Name="DeselectAllCandidatesButton" MinWidth="108" Height="32" Padding="12,0" Margin="4,0,0,0" Content="Select none" loc:Localize.ContentKey="Select none" Click="DeselectAllCandidatesButton_Click"/>
                            <Button x:Name="AddManualCandidateButton" MinWidth="72" Height="32" Padding="12,0" Margin="4,0,0,0" Content="Add" loc:Localize.ContentKey="Add" Click="AddManualCandidateButton_Click"/>
                            <Button x:Name="DeleteSelectedCandidatesButton" MinWidth="82" Height="32" Padding="12,0" Margin="4,0,0,0" Content="Delete" loc:Localize.ContentKey="Delete" Click="DeleteSelectedCandidatesButton_Click"/>
                            <Button x:Name="AddToOverlayButton" MinWidth="118" Height="32" Padding="12,0" Margin="4,0,0,0" Content="Add to overlay" loc:Localize.ContentKey="Add to overlay" Click="AddToOverlayButton_Click"/>
                            <Button x:Name="ClearCandidatesButton" MinWidth="72" Height="32" Padding="12,0" Margin="4,0,0,0" Content="Clear" loc:Localize.ContentKey="Clear" Click="ClearCandidatesButton_Click"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource GlassCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardHeaderStyle}">
                            <TextBlock Text="Overlay Layout" loc:Localize.TextKey="Overlay Layout" Style="{StaticResource SectionTitleStyle}"/>
                        </Border>

                        <Border Grid.Row="1" Margin="14,12" Style="{StaticResource InsetPanelStyle}">
                            <StackPanel>
                                <TextBlock x:Name="LayoutSummaryText" Style="{StaticResource MonoSummaryStyle}"/>
                                <TextBlock Margin="0,8,0,0"
                                           Text="Use the layout editor to size the canvas, arrange slots, set screen position, opacity, scale, hotkey, and refresh interval."
                                           loc:Localize.TextKey="Use the layout editor to size the canvas, arrange slots, set screen position, opacity, scale, hotkey, and refresh interval."
                                           Style="{StaticResource MutedTextStyle}"/>
                            </StackPanel>
                        </Border>

                        <WrapPanel Grid.Row="2" HorizontalAlignment="Right" Margin="14,0,14,14">
                            <Button x:Name="OpenLayoutEditorButton" MinWidth="126" Height="34" Padding="12,0" Margin="4,0,0,0" Content="Manage Layout" loc:Localize.ContentKey="Manage Layout" Click="OpenLayoutEditorButton_Click"/>
                            <Button x:Name="ClearLayoutButton" MinWidth="66" Height="34" Padding="12,0" Margin="4,0,0,0" Content="Clear" loc:Localize.ContentKey="Clear" Click="ClearLayoutButton_Click"/>
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="4" Padding="12,8" Style="{StaticResource GlassCardStyle}">
            <TextBlock x:Name="StatusText"
                       Style="{StaticResource MutedTextStyle}"
                       Text="The base UI is not topmost. The overlay is click-through. Configure the stop hotkey before Start."
                       loc:Localize.TextKey="The base UI is not topmost. The overlay is click-through. Configure the stop hotkey before Start."/>
        </Border>
    </Grid>
</Window>
