<Window x:Class="TestOverlay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mabinogi Cooldown Overlay MVP"
        Height="900"
        Width="1320"
        MinHeight="720"
        MinWidth="1100"
        Background="#F3F5F7">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="14" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="게임 창 선택" FontWeight="SemiBold" Foreground="#20242B"/>
                    <ComboBox x:Name="WindowCombo"
                              Margin="0,8,12,0"
                              Height="34"
                              DisplayMemberPath="DisplayName"/>
                    <TextBlock x:Name="WindowStatusText" Margin="0,6,0,0" Foreground="#596273"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="RefreshWindowsButton" Width="110" Height="36" Margin="8,20,0,0" Content="새로고침" Click="RefreshWindowsButton_Click"/>
                <Button Grid.Column="2" x:Name="VerifyWgcButton" Width="120" Height="36" Margin="8,20,0,0" Content="WGC 확인" Click="VerifyWgcButton_Click"/>
                <Button Grid.Column="3" x:Name="CaptureButton" Width="110" Height="36" Margin="8,20,0,0" Content="캡처" Click="CaptureButton_Click"/>
                <Button Grid.Column="4" x:Name="DetectButton" Width="120" Height="36" Margin="8,20,0,0" Content="후보 탐지" Click="DetectButton_Click"/>
                <Button Grid.Column="5" x:Name="StopOverlayButton" Width="120" Height="36" Margin="8,20,0,0" Content="오버레이 중지" Click="StopOverlayButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="430"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="14">
                        <TextBlock Text="캡처 및 슬롯 후보" FontSize="16" FontWeight="SemiBold" Foreground="#20242B"/>
                        <TextBlock x:Name="CaptureInfoText" DockPanel.Dock="Right" Foreground="#596273"/>
                    </DockPanel>
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#111827">
                        <Canvas x:Name="CaptureCanvas" Background="#111827" MouseLeftButtonDown="CaptureCanvas_MouseLeftButtonDown">
                            <Image x:Name="CaptureImage" Stretch="None"/>
                        </Canvas>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.1*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="탐지/보정" FontSize="16" FontWeight="SemiBold" Foreground="#20242B"/>

                        <Grid Grid.Row="1" Margin="0,12,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="최소 슬롯 크기"/>
                                <Slider x:Name="MinSlotSizeSlider" Minimum="16" Maximum="80" Value="24" TickFrequency="2" IsSnapToTickEnabled="True"/>
                                <TextBlock x:Name="MinSlotSizeText"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="최대 슬롯 크기"/>
                                <Slider x:Name="MaxSlotSizeSlider" Minimum="24" Maximum="96" Value="64" TickFrequency="2" IsSnapToTickEnabled="True"/>
                                <TextBlock x:Name="MaxSlotSizeText"/>
                            </StackPanel>
                        </Grid>

                        <ListBox Grid.Row="2" x:Name="CandidateList" ItemsSource="{Binding Candidates}" BorderBrush="#D9DEE7">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Content="{Binding Label}" Margin="4"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button x:Name="AddSelectedButton" Width="150" Height="34" Content="선택 슬롯 배치" Click="AddSelectedButton_Click"/>
                            <Button x:Name="ClearCandidatesButton" Width="120" Height="34" Margin="8,0,0,0" Content="후보 비우기" Click="ClearCandidatesButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="오버레이 캔버스" FontSize="16" FontWeight="SemiBold" Foreground="#20242B"/>

                        <Grid Grid.Row="1" Margin="0,12,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="너비"/>
                                <TextBox x:Name="OverlayWidthBox" Text="360"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                <TextBlock Text="높이"/>
                                <TextBox x:Name="OverlayHeightBox" Text="160"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="투명도"/>
                                <Slider x:Name="OpacitySlider" Minimum="0.2" Maximum="1" Value="0.8" TickFrequency="0.05"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="화면 X"/>
                                    <TextBox x:Name="OverlayLeftBox" Text="120"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                    <TextBlock Text="화면 Y"/>
                                    <TextBox x:Name="OverlayTopBox" Text="120"/>
                                </StackPanel>
                                <Button Grid.Column="2" x:Name="UseDefaultOverlayPositionButton" Width="110" Height="28" Margin="8,17,0,0" Content="기본 위치" Click="UseDefaultOverlayPositionButton_Click"/>
                            </Grid>

                            <Border Grid.Row="1" BorderBrush="#2F3645" BorderThickness="1" Background="#202633">
                                <Canvas x:Name="LayoutCanvas" Width="360" Height="160" Background="#202633"
                                        MouseLeftButtonUp="LayoutCanvas_MouseLeftButtonUp"
                                        MouseMove="LayoutCanvas_MouseMove"/>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button x:Name="ApplyCanvasButton" Width="120" Height="34" Content="캔버스 적용" Click="ApplyCanvasButton_Click"/>
                            <Button x:Name="StartOverlayButton" Width="120" Height="34" Margin="8,0,0,0" Content="시작" Click="StartOverlayButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Foreground="#596273"
                   Text="Ctrl+Shift+F8로 실행 중인 오버레이를 중지할 수 있습니다. 베이스 UI는 항상 위로 설정하지 않습니다."/>
    </Grid>
</Window>
