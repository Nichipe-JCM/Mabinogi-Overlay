<Window x:Class="TestOverlay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mabinogi Cooldown Overlay"
        Height="920"
        Width="1420"
        MinHeight="760"
        MinWidth="1120"
        Background="#F3F5F7"
        KeyDown="Window_KeyDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="1. Window Capture" FontWeight="SemiBold" Foreground="#20242B"/>
                    <ComboBox x:Name="WindowCombo" Margin="0,8,12,0" Height="34" DisplayMemberPath="DisplayName"/>
                    <TextBlock x:Name="WindowStatusText" Margin="0,6,0,0" Foreground="#596273"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="RefreshWindowsButton" Width="92" Height="34" Margin="8,20,0,0" Content="Refresh" Click="RefreshWindowsButton_Click"/>
                <Button Grid.Column="2" x:Name="VerifyWgcButton" Width="112" Height="34" Margin="8,20,0,0" Content="Verify WGC" Click="VerifyWgcButton_Click"/>
                <Button Grid.Column="3" x:Name="CaptureButton" Width="94" Height="34" Margin="8,20,0,0" Content="Capture" Click="CaptureButton_Click"/>
                <Button Grid.Column="4" x:Name="DetectButton" Width="104" Height="34" Margin="8,20,0,0" Content="Detect" Click="DetectButton_Click"/>
                <Button Grid.Column="5" x:Name="StopOverlayButton" Width="104" Height="34" Margin="8,20,0,0" Content="Stop" Click="StopOverlayButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="520"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="14">
                        <TextBlock Text="Capture Preview" FontSize="16" FontWeight="SemiBold" Foreground="#20242B"/>
                        <TextBlock x:Name="CaptureInfoText" DockPanel.Dock="Right" Foreground="#596273"/>
                    </DockPanel>
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#111827">
                        <Canvas x:Name="CaptureCanvas"
                                Background="#111827"
                                MouseLeftButtonDown="CaptureCanvas_MouseLeftButtonDown"
                                MouseMove="CaptureCanvas_MouseMove"
                                MouseLeftButtonUp="CaptureCanvas_MouseLeftButtonUp">
                            <Image x:Name="CaptureImage" Stretch="None"/>
                        </Canvas>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.05*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="1.05*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="2. Slot Candidates" FontSize="16" FontWeight="SemiBold" Foreground="#20242B"/>

                        <Grid Grid.Row="1" Margin="0,12,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Slot size"/>
                                <Slider x:Name="SlotSizeSlider" Minimum="16" Maximum="96" Value="29" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                <TextBlock x:Name="SlotSizeText"/>
                            </StackPanel>
                        </Grid>

                        <ListBox Grid.Row="2"
                                 x:Name="CandidateList"
                                 ItemsSource="{Binding Candidates}"
                                 BorderBrush="#D9DEE7"
                                 KeyDown="CandidateList_KeyDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Content="{Binding Label}" Margin="4"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <WrapPanel Grid.Row="3" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button x:Name="SelectAllCandidatesButton" Width="70" Height="32" Margin="4,0,0,6" Content="All" Click="SelectAllCandidatesButton_Click"/>
                            <Button x:Name="DeselectAllCandidatesButton" Width="70" Height="32" Margin="4,0,0,6" Content="None" Click="DeselectAllCandidatesButton_Click"/>
                            <Button x:Name="AddManualCandidateButton" Width="82" Height="32" Margin="4,0,0,6" Content="Add" Click="AddManualCandidateButton_Click"/>
                            <Button x:Name="DeleteSelectedCandidatesButton" Width="82" Height="32" Margin="4,0,0,6" Content="Delete" Click="DeleteSelectedCandidatesButton_Click"/>
                            <Button x:Name="AddSelectedButton" Width="104" Height="32" Margin="4,0,0,6" Content="Place" Click="AddSelectedButton_Click"/>
                            <Button x:Name="ClearCandidatesButton" Width="72" Height="32" Margin="4,0,0,6" Content="Clear" Click="ClearCandidatesButton_Click"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="8">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="3. Overlay Layout" FontSize="16" FontWeight="SemiBold" Foreground="#20242B"/>

                        <Grid Grid.Row="1" Margin="0,12,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Width"/>
                                <TextBox x:Name="OverlayWidthBox" Text="360"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,8,0">
                                <TextBlock Text="Height"/>
                                <TextBox x:Name="OverlayHeightBox" Text="160"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="Opacity"/>
                                <Slider x:Name="OpacitySlider" Minimum="0.2" Maximum="1" Value="0.8" TickFrequency="0.05"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="3" Margin="8,0,0,0">
                                <TextBlock Text="Slot scale"/>
                                <Slider x:Name="LayoutSlotScaleSlider" Minimum="1" Maximum="3" Value="1.5" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                                <TextBlock x:Name="LayoutSlotScaleText"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Screen X"/>
                                <TextBox x:Name="OverlayLeftBox" Text="120"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,8,0">
                                <TextBlock Text="Screen Y"/>
                                <TextBox x:Name="OverlayTopBox" Text="120"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="Stop hotkey"/>
                                <TextBox x:Name="HotkeyBox" Text="Ctrl+Shift+F8"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="3" Margin="8,0,0,0">
                                <TextBlock Text="Refresh ms"/>
                                <TextBox x:Name="RefreshIntervalBox" Text="500"/>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2" BorderBrush="#2F3645" BorderThickness="1" Background="#202633">
                            <Canvas x:Name="LayoutCanvas" Width="360" Height="160" Background="#202633"
                                    MouseLeftButtonUp="LayoutCanvas_MouseLeftButtonUp"
                                    MouseMove="LayoutCanvas_MouseMove"/>
                        </Border>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button x:Name="UseDefaultOverlayPositionButton" Width="88" Height="34" Content="Default" Click="UseDefaultOverlayPositionButton_Click"/>
                            <Button x:Name="ApplyCanvasButton" Width="72" Height="34" Margin="8,0,0,0" Content="Apply" Click="ApplyCanvasButton_Click"/>
                            <Button x:Name="OpenLayoutEditorButton" Width="84" Height="34" Margin="8,0,0,0" Content="Editor" Click="OpenLayoutEditorButton_Click"/>
                            <Button x:Name="ClearLayoutButton" Width="76" Height="34" Margin="8,0,0,0" Content="Clear" Click="ClearLayoutButton_Click"/>
                            <Button x:Name="SaveProfileButton" Width="64" Height="34" Margin="8,0,0,0" Content="Save" Click="SaveProfileButton_Click"/>
                            <Button x:Name="LoadProfileButton" Width="64" Height="34" Margin="8,0,0,0" Content="Load" Click="LoadProfileButton_Click"/>
                            <Button x:Name="StartOverlayButton" Width="70" Height="34" Margin="8,0,0,0" Content="Start" Click="StartOverlayButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Foreground="#596273"
                   Text="The base UI is not topmost. The overlay is click-through. Configure the stop hotkey before Start."/>
    </Grid>
</Window>
