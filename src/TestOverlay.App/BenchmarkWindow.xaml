<Window x:Class="TestOverlay.App.BenchmarkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TestOverlay.App.Services"
        Title="Benchmark"
        loc:Localize.TitleKey="Benchmark"
        Icon="/Image/AppIcon.ico"
        Width="820"
        Height="560"
        MinWidth="680"
        MinHeight="460"
        Background="{StaticResource OverlayBgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18" Style="{StaticResource AppWindowRootStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Benchmark / Stress Test" loc:Localize.TextKey="Benchmark / Stress Test" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Run controlled renderer stress tests and write benchmark logs." loc:Localize.TextKey="Run controlled renderer stress tests and write benchmark logs." Style="{StaticResource MutedTextStyle}"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,0,0,14" Style="{StaticResource GlassCardStyle}">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="Renderers" loc:Localize.TextKey="Renderers" Style="{StaticResource PanelTitleStyle}"/>
                    <CheckBox x:Name="CpuWpfCheck" Content="Existing CPU/WPF" loc:Localize.ContentKey="Existing CPU/WPF" IsChecked="True" Margin="0,8,0,0"/>
                    <CheckBox x:Name="CpuCompositedCheck" Content="Improved CPU/Composited" loc:Localize.ContentKey="Improved CPU/Composited" IsChecked="True" Margin="0,4,0,0"/>
                    <CheckBox x:Name="GpuDxgiCheck" Content="GPU/DXGI offscreen" loc:Localize.ContentKey="GPU/DXGI offscreen" IsChecked="True" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Text="Stress" loc:Localize.TextKey="Stress" Style="{StaticResource PanelTitleStyle}"/>
                    <TextBlock Text="Duration seconds" loc:Localize.TextKey="Duration seconds" Margin="0,8,0,0" Style="{StaticResource MutedTextStyle}"/>
                    <ComboBox x:Name="DurationCombo" Height="30" SelectedIndex="1">
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="30"/>
                        <ComboBoxItem Content="60"/>
                    </ComboBox>
                    <TextBlock Text="Iterations fallback" loc:Localize.TextKey="Iterations fallback" Margin="0,8,0,0" Style="{StaticResource MutedTextStyle}"/>
                    <ComboBox x:Name="IterationsCombo" Height="30" SelectedIndex="1">
                        <ComboBoxItem Content="60"/>
                        <ComboBoxItem Content="180"/>
                        <ComboBoxItem Content="600"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="4">
                    <TextBlock Text="Load" loc:Localize.TextKey="Benchmark.Load" Style="{StaticResource PanelTitleStyle}"/>
                    <TextBlock Text="Slot multipliers" loc:Localize.TextKey="Slot multipliers" Margin="0,8,0,0" Style="{StaticResource MutedTextStyle}"/>
                    <TextBox x:Name="MultipliersBox" Height="30" Text="1,5,10,20"/>
                    <TextBlock Text="comma-separated" loc:Localize.TextKey="comma-separated" Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}"/>
                    <Button x:Name="StartButton" MinWidth="132" Height="34" Padding="14,0" HorizontalAlignment="Left" Margin="0,12,0,0" Content="Start benchmark" loc:Localize.ContentKey="Start benchmark" Click="StartButton_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock Text="Source size" loc:Localize.TextKey="Source size" Style="{StaticResource MutedTextStyle}"/>
                    <ComboBox x:Name="SourceSizeCombo" Height="30" Margin="0,6,0,0" SelectedIndex="0">
                        <ComboBoxItem Content="1920x1080"/>
                        <ComboBoxItem Content="2560x1440"/>
                        <ComboBoxItem Content="3840x2160"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2">
                    <TextBlock Text="Overlay size" loc:Localize.TextKey="Overlay size" Style="{StaticResource MutedTextStyle}"/>
                    <ComboBox x:Name="OverlaySizeCombo" Height="30" Margin="0,6,0,0" SelectedIndex="0">
                        <ComboBoxItem Content="960x540"/>
                        <ComboBoxItem Content="1280x720"/>
                    </ComboBox>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Grid.Column="4"
                           Text="Synthetic tests isolate renderer cost. Live WGC stats still include capture and composition."
                           loc:Localize.TextKey="Synthetic tests isolate renderer cost. Live WGC stats still include capture and composition."
                           Style="{StaticResource MutedTextStyle}"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock x:Name="StatusText" Style="{StaticResource MutedTextStyle}"/>
            <ProgressBar x:Name="BenchmarkProgress" Height="12" Margin="0,8,0,0" Minimum="0" Maximum="1"/>
        </StackPanel>

        <TextBox Grid.Row="3"
                 x:Name="OutputBox"
                 IsReadOnly="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Cascadia Mono, Consolas"
                 FontSize="12"
                 Background="{StaticResource OverlayPanelSoftBrush}"
                 Foreground="{StaticResource OverlayTextBrush}"
                 BorderBrush="{StaticResource OverlayBorderBrush}"/>

        <WrapPanel Grid.Row="4" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="CloseButton" MinWidth="88" Height="34" Padding="14,0" Content="Close" loc:Localize.ContentKey="Close" Click="CloseButton_Click"/>
        </WrapPanel>
    </Grid>
</Window>
