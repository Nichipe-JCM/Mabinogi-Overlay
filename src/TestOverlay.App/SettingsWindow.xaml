<Window x:Class="TestOverlay.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="760"
        Height="500"
        MinWidth="640"
        MinHeight="440"
        Background="{StaticResource OverlayBgBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18" Style="{StaticResource AppWindowRootStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Settings" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Profiles, storage path, renderer mode, and benchmark tools." Style="{StaticResource MutedTextStyle}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardHeaderStyle}">
                        <TextBlock Text="Profile" Style="{StaticResource SectionTitleStyle}"/>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="14">
                        <TextBlock Text="Active profile" Style="{StaticResource PanelTitleStyle}"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="86"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ProfileCombo" Grid.Column="0" Height="32"/>
                            <Button Grid.Column="1" Height="32" Margin="8,0,0,0" Content="Save" Style="{StaticResource PrimaryActionButtonStyle}" Click="SaveProfileButton_Click"/>
                            <Button Grid.Column="2" Height="32" Margin="8,0,0,0" Content="Load" Click="LoadProfileButton_Click"/>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="2" Margin="14,0,14,14" Style="{StaticResource InsetPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Profile save folder" Style="{StaticResource PanelTitleStyle}"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="86"/>
                                    <ColumnDefinition Width="86"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ProfileDirectoryBox" Grid.Column="0" Height="32"/>
                                <Button Grid.Column="1" Height="32" Margin="8,0,0,0" Content="Browse" Click="BrowseButton_Click"/>
                                <Button Grid.Column="2" Height="32" Margin="8,0,0,0" Content="Default" Click="DefaultButton_Click"/>
                            </Grid>
                            <TextBlock Margin="0,8,0,0"
                                       Text="Portable builds default to a save folder next to the executable."
                                       Style="{StaticResource MutedTextStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource GlassCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardHeaderStyle}">
                        <TextBlock Text="Runtime" Style="{StaticResource SectionTitleStyle}"/>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="14">
                        <TextBlock Text="Overlay renderer" Style="{StaticResource PanelTitleStyle}"/>
                        <ComboBox x:Name="RenderModeCombo" Height="32" Margin="0,8,0,0" DisplayMemberPath="Label"/>
                        <TextBlock Margin="0,8,0,0"
                                   Text="Renderer mode is saved in settings.json and applies when the overlay starts."
                                   Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>

                    <Border Grid.Row="3" Margin="14" Style="{StaticResource InsetPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Benchmark" Style="{StaticResource PanelTitleStyle}"/>
                            <TextBlock Margin="0,6,0,10"
                                       Text="Open a controlled stress test window to compare renderer cost."
                                       Style="{StaticResource MutedTextStyle}"/>
                            <Button Height="34" Content="Open benchmark" Click="BenchmarkButton_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Width="88" Height="34" Content="OK" Style="{StaticResource PrimaryActionButtonStyle}" Click="OkButton_Click"/>
            <Button Width="88" Height="34" Margin="8,0,0,0" Content="Cancel" IsCancel="True"/>
        </WrapPanel>
    </Grid>
</Window>
