<Window x:Class="TestOverlay.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TestOverlay.App.Services"
        xmlns:controls="clr-namespace:TestOverlay.App.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Settings"
        loc:Localize.TitleKey="Settings"
        Icon="/Image/AppIcon.ico"
        Width="1260"
        Height="810"
        MinWidth="960"
        MinHeight="720"
        Background="{StaticResource OverlayBgBrush}"
        WindowStartupLocation="CenterOwner">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="7"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid Margin="8,4,8,8" Style="{StaticResource AppWindowRootStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:AppTitleBar Grid.Row="0"/>


        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="Settings" loc:Localize.TextKey="Settings" FontSize="22" FontWeight="Bold" Foreground="{StaticResource OverlayAccentBrush}"/>
            <TextBlock Text="Profiles, storage path, capture method, renderer mode, and benchmark tools." loc:Localize.TextKey="Profiles, storage path, capture method, renderer mode, and benchmark tools." Style="{StaticResource MutedTextStyle}"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardHeaderStyle}">
                        <TextBlock Text="Profile" loc:Localize.TextKey="Profile" Style="{StaticResource SectionTitleStyle}"/>
                    </Border>

                    <Border Grid.Row="1" Margin="14" MinHeight="104" Style="{StaticResource InsetPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Active profile" loc:Localize.TextKey="Active profile" Style="{StaticResource PanelTitleStyle}"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="86"/>
                                    <ColumnDefinition Width="86"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="ProfileCombo" Grid.Column="0" Height="40"/>
                                <Button Grid.Column="1" MinWidth="86" Height="40" Padding="12,0" Margin="8,0,0,0" Content="Save" loc:Localize.ContentKey="Save" Click="SaveProfileButton_Click"/>
                                <Button Grid.Column="2" MinWidth="86" Height="40" Padding="12,0" Margin="8,0,0,0" Content="Load" loc:Localize.ContentKey="Load" Click="LoadProfileButton_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Margin="14,0,14,14" MinHeight="118" Style="{StaticResource InsetPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Profile save folder" loc:Localize.TextKey="Profile save folder" Style="{StaticResource PanelTitleStyle}"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="86"/>
                                    <ColumnDefinition Width="86"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ProfileDirectoryBox" Grid.Column="0" Height="40"/>
                                <Button Grid.Column="1" MinWidth="86" Height="40" Padding="12,0" Margin="8,0,0,0" Content="Browse" loc:Localize.ContentKey="Browse" Click="BrowseButton_Click"/>
                                <Button Grid.Column="2" MinWidth="86" Height="40" Padding="12,0" Margin="8,0,0,0" Content="Default" loc:Localize.ContentKey="Default" Click="DefaultButton_Click"/>
                            </Grid>
                            <TextBlock Margin="0,8,0,0"
                                       Text="Portable builds default to a save folder next to the executable."
                                       loc:Localize.TextKey="Portable builds default to a save folder next to the executable."
                                       Style="{StaticResource MutedTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" Margin="14,0,14,14" MinHeight="104" Style="{StaticResource InsetPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Language" loc:Localize.TextKey="Language" Style="{StaticResource PanelTitleStyle}"/>
                            <ComboBox x:Name="LanguageCombo" Height="40" Margin="0,8,0,0" DisplayMemberPath="Label"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource GlassCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardHeaderStyle}">
                        <TextBlock Text="Runtime" loc:Localize.TextKey="Runtime" Style="{StaticResource SectionTitleStyle}"/>
                    </Border>

                    <Border Grid.Row="1" Margin="14" MinHeight="126" Style="{StaticResource InsetPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Overlay renderer" loc:Localize.TextKey="Overlay renderer" Style="{StaticResource PanelTitleStyle}"/>
                            <ComboBox x:Name="RenderModeCombo" Height="40" Margin="0,8,0,0" DisplayMemberPath="Label"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="Renderer mode is saved in settings.json and applies when the overlay starts."
                                       loc:Localize.TextKey="Renderer mode is saved in settings.json and applies when the overlay starts."
                                       Style="{StaticResource MutedTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Margin="14,0,14,14" MinHeight="126" Style="{StaticResource InsetPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Capture method" loc:Localize.TextKey="Capture method" Style="{StaticResource PanelTitleStyle}"/>
                            <ComboBox x:Name="CaptureBackendCombo" Height="40" Margin="0,8,0,0" DisplayMemberPath="Label"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="Choose how the running overlay refreshes its slot images. DXGI captures the monitor and is the default low-friction option. GDI is a compatibility fallback. WGC captures the selected game window more directly, but Windows may show a yellow capture border while it is active."
                                       loc:Localize.TextKey="capture.method.description"
                                       Style="{StaticResource MutedTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" Margin="14,0,14,14" MinHeight="150" Style="{StaticResource InsetPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Benchmark" loc:Localize.TextKey="Benchmark" Style="{StaticResource PanelTitleStyle}"/>
                            <TextBlock Margin="0,6,0,10"
                                       Text="Open a controlled stress test window to compare renderer cost."
                                       loc:Localize.TextKey="Open a controlled stress test window to compare renderer cost."
                                       Style="{StaticResource MutedTextStyle}"/>
                            <Button MinWidth="120" Height="34" Padding="12,0" HorizontalAlignment="Left" Content="Open benchmark" loc:Localize.ContentKey="Open benchmark" Click="BenchmarkButton_Click"/>
                            <Button MinWidth="70" Height="34" Padding="12,0" HorizontalAlignment="Left" Margin="0,8,0,0" Content="Log" loc:Localize.ContentKey="Log" Click="LogButton_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <WrapPanel Grid.Row="3" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button MinWidth="88" Height="34" Padding="14,0" Content="OK" loc:Localize.ContentKey="OK" Click="OkButton_Click"/>
            <Button MinWidth="88" Height="34" Padding="14,0" Margin="8,0,0,0" Content="Cancel" loc:Localize.ContentKey="Cancel" IsCancel="True"/>
        </WrapPanel>
    </Grid>
</Window>

