<Window x:Class="TestOverlay.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="640"
        Height="220"
        MinWidth="520"
        MinHeight="200"
        Background="#F3F5F7"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Profile save folder"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#20242B"/>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ProfileDirectoryBox" Grid.Column="0" Height="30" VerticalContentAlignment="Center"/>
            <Button Grid.Column="1" Width="84" Height="30" Margin="8,0,0,0" Content="Browse" Click="BrowseButton_Click"/>
            <Button Grid.Column="2" Width="84" Height="30" Margin="8,0,0,0" Content="Default" Click="DefaultButton_Click"/>
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="0,10,0,0"
                   Foreground="#596273"
                   TextWrapping="Wrap"
                   Text="Profiles are saved as JSON files in this folder. The portable default is the save folder next to the executable."/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="84" Height="32" Content="OK" Click="OkButton_Click"/>
            <Button Width="84" Height="32" Margin="8,0,0,0" Content="Cancel" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
